# Copy this file to .env.local and fill in your Supabase project credentials.
# Get these from: https://supabase.com/dashboard → your project → Settings → API

# Public URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose to the browser (governed by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY, never expose to the browser
# Used by API routes for unrestricted DB access
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
